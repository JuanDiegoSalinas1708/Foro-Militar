@{
    ViewBag.Title = "Panel de Administración";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-hero {
        background: linear-gradient(135deg, #0d1b2a 0%, #1a2a3a 100%);
        padding: 36px 40px;
        border-bottom: 1px solid #2c4a6e;
    }

        .admin-hero h2 {
            color: #fff;
            font-weight: 800;
            margin: 0;
            font-size: 1.6rem;
        }

        .admin-hero p {
            color: #6b7c8d;
            margin: 6px 0 0;
            font-size: 0.88rem;
        }

    .admin-body {
        padding: 32px 40px;
        background: #f0f2f5;
        min-height: calc(100vh - 160px);
    }

    .section-title {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6b7c8d;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #dce3ea;
        }

    /* Stats */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .stat-mini {
        background: #fff;
        border-radius: 10px;
        padding: 18px 20px;
        border: 1px solid #e8eef4;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
    }

        .stat-mini .ico {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .stat-mini .val {
            font-size: 1.6rem;
            font-weight: 800;
            line-height: 1;
            color: #1a2a3a;
        }

        .stat-mini .lbl {
            font-size: 0.75rem;
            color: #6b7c8d;
            margin-top: 2px;
        }

    /* Foros grid */
    .foros-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }

    .foro-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e8eef4;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .foro-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        }

    .foro-card-header {
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .foro-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .foro-card-info h5 {
        margin: 0;
        font-weight: 700;
        color: #1a2a3a;
        font-size: 1rem;
    }

    .foro-card-info p {
        margin: 3px 0 0;
        color: #6b7c8d;
        font-size: 0.78rem;
    }

    .foro-card-body {
        padding: 0 20px 16px;
        display: flex;
        gap: 16px;
    }

    .foro-stat {
        text-align: center;
    }

        .foro-stat .n {
            font-size: 1.2rem;
            font-weight: 800;
            color: #1a2a3a;
        }

        .foro-stat .l {
            font-size: 0.7rem;
            color: #9ab0c4;
        }

    .foro-card-footer {
        border-top: 1px solid #f0f2f5;
        padding: 12px 20px;
        display: flex;
        gap: 8px;
        background: #fafbfc;
    }

    .btn-gestionar {
        flex: 1;
        background: #2c4a6e;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: background 0.2s;
    }

        .btn-gestionar:hover {
            background: #3a5a8e;
            color: #fff;
        }

    .btn-config {
        background: #f0f2f5;
        color: #6b7c8d;
        border: none;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 0.82rem;
        transition: background 0.2s;
        cursor: pointer;
    }

        .btn-config:hover {
            background: #e0e4e8;
            color: #1a2a3a;
        }

    /* Badge próximamente */
    .badge-soon {
        background: #f0f2f5;
        color: #9ab0c4;
        font-size: 0.65rem;
        padding: 3px 8px;
        border-radius: 20px;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    /* Card agregar foro */
    .foro-card-add {
        background: #fafbfc;
        border: 2px dashed #dce3ea;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 32px;
        cursor: pointer;
        transition: all 0.2s;
        min-height: 180px;
    }

        .foro-card-add:hover {
            border-color: #4a7fa5;
            background: #eef4fa;
        }

        .foro-card-add i {
            font-size: 1.8rem;
            color: #c0ccd8;
        }

        .foro-card-add span {
            color: #9ab0c4;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .foro-card-add:hover i,
        .foro-card-add:hover span {
            color: #4a7fa5;
        }

    /* Actividad reciente */
    .actividad-lista {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e8eef4;
        overflow: hidden;
    }

    .actividad-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid #f0f2f5;
        transition: background 0.15s;
    }

        .actividad-item:last-child {
            border-bottom: none;
        }

        .actividad-item:hover {
            background: #f8f9fb;
        }

    .act-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .act-info {
        flex: 1;
    }

        .act-info strong {
            display: block;
            font-size: 0.85rem;
            color: #1a2a3a;
            font-weight: 600;
        }

        .act-info span {
            font-size: 0.75rem;
            color: #9ab0c4;
        }

    .act-foro {
        font-size: 0.72rem;
        background: #eef4fa;
        color: #4a7fa5;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 600;
        white-space: nowrap;
    }
</style>

<!-- Hero -->
<div class="admin-hero">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fa fa-gauge me-2" style="color:#4a7fa5;"></i>Panel de Administración</h2>
            <p>Gestiona todos los foros y publicaciones de la plataforma</p>
        </div>
    </div>
</div>

<div class="admin-body">

    <!-- Stats globales -->
    <div class="section-title"><i class="fa fa-chart-bar"></i> Resumen Global</div>

    <div class="stats-row">
        <div class="stat-mini">
            <div class="ico" style="background:#eef4fa;">
                <i class="fa fa-layer-group" style="color:#4a7fa5;"></i>
            </div>
            <div>
                <div class="val" id="statForos">1</div>
                <div class="lbl">Foros activos</div>
            </div>
        </div>

        <div class="stat-mini">
            <div class="ico" style="background:#fdeaea;">
                <i class="fa fa-fire" style="color:#b33030;"></i>
            </div>
            <div>
                <div class="val" id="statConflictosActivos" style="color:#b33030;">—</div>
                <div class="lbl">Conflictos activos</div>
            </div>
        </div>

        <div class="stat-mini">
            <div class="ico" style="background:#f0f7f0;">
                <i class="fa fa-database" style="color:#2a6e3a;"></i>
            </div>
            <div>
                <div class="val" id="statTotal" style="color:#2a6e3a;">—</div>
                <div class="lbl">Total publicaciones</div>
            </div>
        </div>

        <div class="stat-mini">
            <div class="ico" style="background:#fff8e8;">
                <i class="fa fa-map-marker-alt" style="color:#a07520;"></i>
            </div>
            <div>
                <div class="val" id="statPaises" style="color:#a07520;">—</div>
                <div class="lbl">Países registrados</div>
            </div>
        </div>
    </div>

    <!-- Foros -->
    <div class="section-title"><i class="fa fa-layer-group"></i> Foros de la Plataforma</div>

    <div class="foros-grid">

        <!-- Foro Militar (activo) -->
        <div class="foro-card">
            <div class="foro-card-header">
                <div class="foro-card-icon" style="background:#eef4fa;">
                    <i class="fa-solid fa-shield-halved" style="color:#2c4a6e;"></i>
                </div>
                <div class="foro-card-info">
                    <h5>Foro Militar</h5>
                    <p>Conflictos armados y eventos históricos</p>
                </div>
            </div>
            <div class="foro-card-body">
                <div class="foro-stat">
                    <div class="n" id="totalMilitar">—</div>
                    <div class="l">Publicaciones</div>
                </div>
                <div class="foro-stat">
                    <div class="n" id="activosMilitar" style="color:#b33030;">—</div>
                    <div class="l">Activos</div>
                </div>
                <div class="foro-stat">
                    <div class="n" id="paisesMilitar" style="color:#2a6e3a;">—</div>
                    <div class="l">Países</div>
                </div>
            </div>
            <div class="foro-card-footer">
                <a href="@Url.Action("Index", "ForoView")" class="btn-gestionar">
                    <i class="fa fa-arrow-right"></i> Gestionar
                </a>
                <a href="@Url.Action("Index", "GloboView")" class="btn-config" title="Ver globo">
                    <i class="fa-solid fa-earth-americas"></i>
                </a>
            </div>
        </div>

        <!-- Foros próximamente -->
        <div class="foro-card" style="opacity:0.7;">
            <div class="foro-card-header">
                <div class="foro-card-icon" style="background:#f0f7f0;">
                    <i class="fa fa-futbol" style="color:#2a6e3a;"></i>
                </div>
                <div class="foro-card-info">
                    <h5>Foro Deportes <span class="badge-soon ms-1">Próximamente</span></h5>
                    <p>Noticias y eventos deportivos</p>
                </div>
            </div>
            <div class="foro-card-footer">
                <button class="btn-gestionar" style="background:#9ab0c4; cursor:not-allowed;">
                    <i class="fa fa-lock"></i> No disponible
                </button>
            </div>
        </div>

        <div class="foro-card" style="opacity:0.7;">
            <div class="foro-card-header">
                <div class="foro-card-icon" style="background:#fdf0ff;">
                    <i class="fa fa-microchip" style="color:#7a3a9e;"></i>
                </div>
                <div class="foro-card-info">
                    <h5>Foro Tecnología <span class="badge-soon ms-1">Próximamente</span></h5>
                    <p>Avances tecnológicos y tendencias</p>
                </div>
            </div>
            <div class="foro-card-footer">
                <button class="btn-gestionar" style="background:#9ab0c4; cursor:not-allowed;">
                    <i class="fa fa-lock"></i> No disponible
                </button>
            </div>
        </div>

        <div class="foro-card" style="opacity:0.7;">
            <div class="foro-card-header">
                <div class="foro-card-icon" style="background:#fff8e8;">
                    <i class="fa fa-landmark" style="color:#a07520;"></i>
                </div>
                <div class="foro-card-info">
                    <h5>Foro Política <span class="badge-soon ms-1">Próximamente</span></h5>
                    <p>Análisis político y geopolítica</p>
                </div>
            </div>
            <div class="foro-card-footer">
                <button class="btn-gestionar" style="background:#9ab0c4; cursor:not-allowed;">
                    <i class="fa fa-lock"></i> No disponible
                </button>
            </div>
        </div>

        <!-- Agregar nuevo foro -->
        <div class="foro-card-add" onclick="alert('Próximamente podrás crear nuevos foros desde aquí.')">
            <i class="fa fa-plus-circle"></i>
            <span>Agregar nuevo foro</span>
        </div>

    </div>

    <!-- Actividad reciente -->
    <div class="section-title"><i class="fa fa-clock"></i> Actividad Reciente</div>

    <div class="actividad-lista" id="actividadLista">
        <div class="actividad-item">
            <div class="act-icon" style="background:#f0f2f5;">
                <i class="fa fa-spinner fa-spin" style="color:#9ab0c4;"></i>
            </div>
            <div class="act-info">
                <strong>Cargando...</strong>
            </div>
        </div>
    </div>

</div>

@section scripts {
    <script>document.addEventListener('DOMContentLoaded', function () {
        fetch('/api/Foro')
            .then(res => res.json())
            .then(data => {
                const total   = data.length;
                const activos = data.filter(f => f.Activa === true).length;
                const paises  = new Set(data.map(f => (f.Pais || '').trim().toLowerCase()).filter(p => p !== ''));

                // Stats globales
                animarContador('statTotal', total);
                animarContador('statConflictosActivos', activos);
                animarContador('statPaises', paises.size);

                // Stats foro militar
                animarContador('totalMilitar', total);
                animarContador('activosMilitar', activos);
                animarContador('paisesMilitar', paises.size);

                // Actividad reciente — últimos 5
                const recientes = [...data].reverse().slice(0, 5);
                const lista = document.getElementById('actividadLista');
                lista.innerHTML = '';

                recientes.forEach(f => {
                    const fecha  = f.Fecha ? f.Fecha.split('T')[0] : '';
                    const activa = f.Activa
                        ? `<span style="color:#b33030; font-size:0.7rem;"><i class="fa fa-circle me-1"></i>Activo</span>`
                        : `<span style="color:#9ab0c4; font-size:0.7rem;"><i class="fa fa-circle me-1"></i>Histórico</span>`;

                    lista.innerHTML += `
                    <div class="actividad-item">
                        <div class="act-icon" style="background:#eef4fa;">
                            <i class="fa-solid fa-shield-halved" style="color:#2c4a6e;"></i>
                        </div>
                        <div class="act-info">
                            <strong>${f.Titulo}</strong>
                            <span>${fecha} · ${f.Pais || 'Sin país'} · ${activa}</span>
                        </div>
                        <span class="act-foro">Militar</span>
                    </div>`;
                });
            });
    });

    function animarContador(id, objetivo) {
        const el = document.getElementById(id);
        if (!el) return;
        let actual = 0;
        const paso = Math.ceil(objetivo / 30);
        const intervalo = setInterval(() => {
            actual = Math.min(actual + paso, objetivo);
            el.innerText = actual;
            if (actual >= objetivo) clearInterval(intervalo);
        }, 40);
    }</script>
}
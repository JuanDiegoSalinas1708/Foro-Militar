@model Foro_Militar.Models.DashboardHomeViewModel

<div class="top-communities-section">

    <div class="section-header">
        <h2>🔥 Comunidades Destacadas</h2>
        <span>Las más influyentes ahora mismo</span>
    </div>

    <div class="top-communities-grid">

        @{
            var ranking = 1;
        }

        @foreach (var community in Model.MostFollowedCommunities.Take(3))
        {
            <div class="community-card reveal">

                <div class="community-rank">
                    #@ranking
                </div>

                <div class="community-content">

                    <div class="community-header">
                        <div class="community-avatar">
                            @community.Name.Substring(0, 1).ToUpper()
                        </div>

                        <div>
                            <h3>@community.Name</h3>
                            <p>
                                @(community.Description?.Length > 80
                                ? community.Description.Substring(0,80) + "..."
                                : community.Description)
                            </p>
                        </div>
                    </div>

                    <div class="community-stats">

                        <div class="stat-box">
                            <span>Seguidores</span>
                            <strong>@community.UserCommunities.Count</strong>
                        </div>

                        <div class="stat-box">
                            <span>Posts</span>
                            <strong>@community.Posts.Count</strong>
                        </div>

                        <div class="stat-box">
                            <span>Creada</span>
                            <strong>@community.CreatedAt.ToString("MMM yyyy")</strong>
                        </div>

                    </div>

                    <div class="community-footer">
                        <a href="@Url.Action("Details","Community", new { id = community.Id })"
                           class="explore-btn">
                            Explorar →
                        </a>
                    </div>

                </div>

            </div>

            ranking++;
        }

    </div>
</div>
@{
    ViewBag.Title = "Foro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold" style="color:#1A225C;">
            <i class="fa-solid fa-layer-group" style="color:#A9A9C7;"></i>
            <span id="nombreComunidad">Foro</span>
        </h3>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index", "GloboView")" class="btn btn-globe px-4">
                <i class="fa-solid fa-earth-americas me-1"></i> Conflictos Activos
            </a>
            <button class="btn btn-primary-custom px-4" onclick="abrirModalCrear()">
                <i class="fa fa-plus"></i> Nueva Publicación
            </button>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle text-center mb-0">
                <thead class="thead-custom">
                    <tr>
                        <th>#</th>
                        <th>Título</th>
                        <th>Contenido</th>
                        <th>País</th>
                        <th>Fecha</th>
                        <th>Imagen</th>
                        <th>Estado</th>
                        <th style="width:120px;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaForo"></tbody>
            </table>
            <div id="paginacion"></div>
        </div>
    </div>
</div>

<!-- MODAL VER DETALLE -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title" id="detalleTitulo"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="background-color:#f8f9fb;">
                <div class="row g-0">
                    <div class="col-md-5 d-flex align-items-center justify-content-center"
                         style="background-color:#1A225C; min-height:280px;">
                        <img id="detalleImagen" src="" alt="Imagen"
                             style="max-width:100%; max-height:320px; object-fit:contain; padding:16px;"
                             onerror="this.style.display='none'; document.getElementById('sinImagen').style.display='flex';">
                        <div id="sinImagen"
                             style="display:none; flex-direction:column; align-items:center; justify-content:center; color:#A9A9C7; padding:20px;">
                            <i class="fa fa-image fa-3x mb-2"></i>
                            <span>Sin imagen</span>
                        </div>
                    </div>
                    <div class="col-md-7 p-4">
                        <div class="d-flex gap-2 mb-3 flex-wrap">
                            <span class="badge" style="background-color:#1A225C; font-size:0.8rem;">
                                <i class="fa fa-calendar me-1"></i>
                                <span id="detalleFecha"></span>
                            </span>
                            <span class="badge" style="background-color:#3a6a3a; font-size:0.8rem;">
                                <i class="fa fa-map-marker me-1"></i>
                                <span id="detallePais"></span>
                            </span>
                            <span id="detalleActivaBadge" class="badge" style="font-size:0.8rem;"></span>
                        </div>
                        <h6 class="fw-bold mb-2" style="color:#1A225C;">Descripción</h6>
                        <p id="detalleHechos" style="color:#1A225C; line-height:1.7; text-align:justify;"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="background-color:#f0f2f5;">
                <button class="btn btn-secondary-custom" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL CREAR / EDITAR -->
<div class="modal fade" id="modalForo" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title" id="modalTitulo"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="background-color:#f8f9fb;">
                <input type="hidden" id="postId">

                <div class="mb-3">
                    <label class="form-label fw-semibold label-custom">Título</label>
                    <input type="text" id="inputTitle" class="form-control input-custom"
                           placeholder="Título de la publicación" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold label-custom">Contenido / Hechos</label>
                    <textarea id="inputContent" class="form-control input-custom" rows="4"
                              placeholder="Descripción detallada..." required></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold label-custom">País(es)</label>
                        <input type="text" id="inputCountry" class="form-control input-custom"
                               placeholder="Ej: Colombia, Venezuela">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold label-custom">Imagen (URL)</label>
                        <input type="text" id="inputImage" class="form-control input-custom"
                               placeholder="https://...">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold label-custom">Categoría principal</label>
                    <select id="inputCategory" class="form-select input-custom">
                        <option value="">Cargando categorías...</option>
                    </select>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="inputActivo"
                               style="width:2.5em; height:1.3em;" checked>
                        <label class="form-check-label fw-semibold label-custom ms-2" for="inputActivo">
                            ¿Publicación activa?
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="background-color:#f0f2f5;">
                <button class="btn btn-secondary-custom" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary-custom px-4" onclick="guardarPost()">
                    <i class="fa fa-save me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL ELIMINAR -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header" style="background-color:#b33030; color:white; border-radius:10px 10px 0 0;">
                <h6 class="modal-title">Confirmar eliminación</h6>
            </div>
            <div class="modal-body text-center" style="color:#1A225C; background-color:#f8f9fb;">
                ¿Está seguro que desea eliminar esta publicación?
                <input type="hidden" id="idEliminar">
            </div>
            <div class="modal-footer" style="background-color:#f0f2f5;">
                <button class="btn btn-secondary-custom btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-danger-custom btn-sm" onclick="confirmarEliminar()">Eliminar</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --color-navy: #1A225C;
        --color-steel: #1A225C;
        --color-accent: #A9A9C7;
        --color-accent-hover: #1A225C;
        --color-border: #d0d0e8;
        --color-danger: #b33030;
        --color-danger-hover: #962828;
        --color-warning: #a07520;
        --color-globe: #2a6e3a;
        --color-globe-hover: #1e5229;
    }

    .card {
        border-radius: 10px;
        overflow: hidden;
    }

    .modal-content {
        border-radius: 10px;
        overflow: hidden;
    }

    .thead-custom {
        background-color: var(--color-steel);
        color: #fff;
    }

        .thead-custom th {
            font-weight: 600;
            letter-spacing: 0.03em;
            padding: 14px 10px;
            border: none;
        }

    table tbody tr {
        color: var(--color-navy);
        cursor: pointer;
    }

        table tbody tr:hover {
            background-color: #e0e0f0;
            transition: background-color 0.2s;
        }

    table tbody td {
        color: var(--color-navy);
        vertical-align: middle;
        padding: 10px;
        border-color: var(--color-border);
    }

        table tbody td:last-child {
            cursor: default;
        }

    .btn-primary-custom {
        background-color: var(--color-accent);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-primary-custom:hover {
            background-color: var(--color-accent-hover);
            color: #fff;
        }

    .btn-secondary-custom {
        background-color: #d0d7de;
        color: var(--color-navy);
        border: none;
        border-radius: 6px;
        font-weight: 500;
    }

        .btn-secondary-custom:hover {
            background-color: #bac3cc;
            color: var(--color-navy);
        }

    .btn-danger-custom {
        background-color: var(--color-danger);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 500;
    }

        .btn-danger-custom:hover {
            background-color: var(--color-danger-hover);
            color: #fff;
        }

    .btn-globe {
        background-color: var(--color-globe);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-globe:hover {
            background-color: var(--color-globe-hover);
            color: #fff;
        }

    .btn-outline-warning {
        color: var(--color-warning) !important;
        border-color: var(--color-warning) !important;
    }

        .btn-outline-warning:hover {
            background-color: var(--color-warning) !important;
            color: #fff !important;
        }

    .btn-outline-danger {
        color: var(--color-danger) !important;
        border-color: var(--color-danger) !important;
    }

        .btn-outline-danger:hover {
            background-color: var(--color-danger) !important;
            color: #fff !important;
        }

    .modal-header-custom {
        background-color: var(--color-steel);
        color: #fff;
    }

    .label-custom {
        color: var(--color-navy);
    }

    .input-custom {
        border-color: var(--color-border);
        color: var(--color-navy);
        background-color: #fff;
    }

        .input-custom:focus {
            border-color: var(--color-accent);
            box-shadow: 0 0 0 0.2rem rgba(169,169,199,0.25);
        }

    img.preview-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid var(--color-border);
    }

    .page-link {
        color: var(--color-steel);
        border-color: var(--color-border);
    }

        .page-link:hover {
            background-color: #e0e0f0;
            color: var(--color-navy);
            border-color: var(--color-border);
        }

    .page-item.active .page-link {
        background-color: var(--color-steel) !important;
        border-color: var(--color-steel) !important;
        color: #fff !important;
    }

    .page-item.disabled .page-link {
        color: #aab4be;
    }
</style>

@section scripts {
    <script>

        // ── Params desde URL ──────────────────────────────────────────────
        const urlParams = new URLSearchParams(window.location.search);
        const communityId = parseInt(urlParams.get('communityId')) || 1;
        const userId = parseInt(urlParams.get('userId')) || 1;

        const apiPosts = '/api/Posts';
        const apiCategories = '/api/Categories';

        let modalForo, modalEliminar, modalDetalle;
        let todosLosRegistros = [];
        let paginaActual = 1;
        const registrosPorPagina = 5;

        // ── Init ──────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            modalForo = new bootstrap.Modal(document.getElementById('modalForo'));
            modalEliminar = new bootstrap.Modal(document.getElementById('modalEliminar'));
            modalDetalle = new bootstrap.Modal(document.getElementById('modalDetalle'));

            cargarCategorias();
            cargarPosts();
        });

        // ── Categorías ────────────────────────────────────────────────────
        function cargarCategorias() {
            fetch(apiCategories)
                .then(res => res.json())
                .then(cats => {
                    const sel = document.getElementById('inputCategory');
                    sel.innerHTML = '<option value="">Selecciona una categoría</option>';
                    cats.forEach(c => {
                        sel.innerHTML += `<option value="${c.Id}">${c.Name}</option>`;
                    });
                })
                .catch(() => {
                    document.getElementById('inputCategory').innerHTML =
                        '<option value="1">General</option>';
                });
        }

        // ── Cargar posts ──────────────────────────────────────────────────
        function cargarPosts() {
            fetch(`${apiPosts}?communityId=${communityId}`)
                .then(res => res.json())
                .then(data => {
                    todosLosRegistros = data;

                    // Nombre de la comunidad en el header
                    if (data.length > 0 && data[0].Community?.Name) {
                        document.getElementById('nombreComunidad').innerText = data[0].Community.Name;
                    }

                    paginaActual = 1;
                    renderTabla();
                })
                .catch(() => {
                    document.getElementById('tablaForo').innerHTML = `
                        <tr><td colspan="8" class="text-center py-4" style="color:#A9A9C7;">
                            <i class="fa fa-exclamation-triangle me-2"></i>No se pudo conectar con la API
                        </td></tr>`;
                });
        }

        // ── Render tabla ──────────────────────────────────────────────────
        function renderTabla() {
            const inicio = (paginaActual - 1) * registrosPorPagina;
            const fin = inicio + registrosPorPagina;
            const pagina = todosLosRegistros.slice(inicio, fin);
            const totalPaginas = Math.ceil(todosLosRegistros.length / registrosPorPagina);

            let html = '';
            pagina.forEach(p => {
                const imgSrc = p.Image
                    ? (p.Image.startsWith('http') ? p.Image : '/Imagenes/' + p.Image)
                    : '';
                const fecha = p.CreatedAt ? p.CreatedAt.split('T')[0] : '—';
                const activaBadge = !p.IsDeleted
                    ? `<span class="badge" style="background-color:#2a6e3a;">Activa</span>`
                    : `<span class="badge" style="background-color:#A9A9C7;">Eliminada</span>`;
                const contenidoCorto = (p.Content || '').substring(0, 80) + ((p.Content || '').length > 80 ? '...' : '');

                html += `
                <tr onclick="verDetalle(${p.Id})">
                    <td>${p.Id}</td>
                    <td class="text-start fw-semibold">${p.Title}</td>
                    <td class="text-start">${contenidoCorto}</td>
                    <td>${p.Country || '—'}</td>
                    <td>${fecha}</td>
                    <td>${imgSrc ? `<img src="${imgSrc}" class="preview-img">` : '—'}</td>
                    <td>${activaBadge}</td>
                    <td onclick="event.stopPropagation()">
                        <button class="btn btn-sm btn-outline-warning me-1" onclick="abrirModalEditar(${p.Id})">
                            <i class="fa fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="eliminar(${p.Id})">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                </tr>`;
            });

            document.getElementById('tablaForo').innerHTML = html || `
                <tr><td colspan="8" class="text-center py-4" style="color:#A9A9C7;">
                    No hay publicaciones aún
                </td></tr>`;

            renderPaginacion(totalPaginas);
        }

        // ── Paginación ────────────────────────────────────────────────────
        function renderPaginacion(totalPaginas) {
            if (todosLosRegistros.length === 0) {
                document.getElementById('paginacion').innerHTML = '';
                return;
            }
            const inicio = ((paginaActual - 1) * registrosPorPagina) + 1;
            const fin = Math.min(paginaActual * registrosPorPagina, todosLosRegistros.length);

            let html = `
            <div class="d-flex justify-content-between align-items-center px-3 py-2"
                 style="background:#f8f9fb; border-top:1px solid #d0d0e8;">
                <small style="color:#A9A9C7;">
                    Mostrando ${inicio}–${fin} de ${todosLosRegistros.length} registros
                </small>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item ${paginaActual === 1 ? 'disabled' : ''}">
                        <button class="page-link" onclick="cambiarPagina(${paginaActual - 1})">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                    </li>`;

            for (let i = 1; i <= totalPaginas; i++) {
                html += `
                    <li class="page-item ${i === paginaActual ? 'active' : ''}">
                        <button class="page-link" onclick="cambiarPagina(${i})">${i}</button>
                    </li>`;
            }

            html += `
                    <li class="page-item ${paginaActual === totalPaginas ? 'disabled' : ''}">
                        <button class="page-link" onclick="cambiarPagina(${paginaActual + 1})">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </div>`;

            document.getElementById('paginacion').innerHTML = html;
        }

        function cambiarPagina(pagina) {
            const totalPaginas = Math.ceil(todosLosRegistros.length / registrosPorPagina);
            if (pagina < 1 || pagina > totalPaginas) return;
            paginaActual = pagina;
            renderTabla();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ── Ver detalle ───────────────────────────────────────────────────
        function verDetalle(id) {
            const p = todosLosRegistros.find(x => x.Id === id);
            if (!p) return;

            document.getElementById('detalleTitulo').innerText = p.Title;
            document.getElementById('detalleHechos').innerText = p.Content;
            document.getElementById('detalleFecha').innerText = p.CreatedAt ? p.CreatedAt.split('T')[0] : '—';
            document.getElementById('detallePais').innerText = p.Country || 'Sin especificar';

            const badge = document.getElementById('detalleActivaBadge');
            badge.innerText = !p.IsDeleted ? '✔ Activo' : '🗑 Eliminado';
            badge.style.backgroundColor = !p.IsDeleted ? '#2a6e3a' : '#A9A9C7';

            const imgSrc = p.Image
                ? (p.Image.startsWith('http') ? p.Image : '/Imagenes/' + p.Image)
                : '';

            const img = document.getElementById('detalleImagen');
            const sinImagen = document.getElementById('sinImagen');
            if (imgSrc) {
                img.src = imgSrc;
                img.style.display = 'block';
                sinImagen.style.display = 'none';
            } else {
                img.style.display = 'none';
                sinImagen.style.display = 'flex';
            }

            modalDetalle.show();
        }

        // ── Crear ─────────────────────────────────────────────────────────
        function abrirModalCrear() {
            limpiarForm();
            document.getElementById('modalTitulo').innerText = 'Nueva Publicación';
            modalForo.show();
        }

        // ── Editar ────────────────────────────────────────────────────────
        function abrirModalEditar(id) {
            const p = todosLosRegistros.find(x => x.Id === id);
            if (!p) return;

            document.getElementById('postId').value = p.Id;
            document.getElementById('inputTitle').value = p.Title;
            document.getElementById('inputContent').value = p.Content;
            document.getElementById('inputCountry').value = p.Country || '';
            document.getElementById('inputImage').value = p.Image || '';
            document.getElementById('inputActivo').checked = !p.IsDeleted;

            // Seleccionar categoría
            const sel = document.getElementById('inputCategory');
            sel.value = p.MainCategoryId || '';

            document.getElementById('modalTitulo').innerText = 'Editar Publicación';
            modalForo.show();
        }

        // ── Guardar (crear o editar) ───────────────────────────────────────
        function guardarPost() {
            const id = document.getElementById('postId').value;
            const title = document.getElementById('inputTitle').value.trim();
            const content = document.getElementById('inputContent').value.trim();
            const catId = document.getElementById('inputCategory').value;

            if (!title || !content) {
                alert('Título y Contenido son obligatorios.');
                return;
            }
            if (!catId) {
                alert('Selecciona una categoría.');
                return;
            }

            const post = {
                Title: title,
                Content: content,
                Country: document.getElementById('inputCountry').value.trim(),
                Image: document.getElementById('inputImage').value.trim(),
                IsDeleted: !document.getElementById('inputActivo').checked,
                UserId: userId,
                CommunityId: communityId,
                MainCategoryId: parseInt(catId)
            };

            if (id) {
                // PUT — editar
                fetch(`${apiPosts}/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(post)
                })
                    .then(res => {
                        if (res.ok) { modalForo.hide(); cargarPosts(); }
                        else alert('Error al actualizar la publicación.');
                    });
            } else {
                // POST — crear
                fetch(apiPosts, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(post)
                })
                    .then(res => {
                        if (res.ok) { modalForo.hide(); cargarPosts(); }
                        else alert('Error al crear la publicación.');
                    });
            }
        }

        // ── Eliminar ──────────────────────────────────────────────────────
        function eliminar(id) {
            document.getElementById('idEliminar').value = id;
            modalEliminar.show();
        }

        function confirmarEliminar() {
            const id = document.getElementById('idEliminar').value;
            fetch(`${apiPosts}/${id}`, { method: 'DELETE' })
                .then(res => {
                    if (res.ok) { modalEliminar.hide(); cargarPosts(); }
                    else alert('Error al eliminar la publicación.');
                });
        }

        // ── Limpiar form ──────────────────────────────────────────────────
        function limpiarForm() {
            document.getElementById('postId').value = '';
            document.getElementById('inputTitle').value = '';
            document.getElementById('inputContent').value = '';
            document.getElementById('inputCountry').value = '';
            document.getElementById('inputImage').value = '';
            document.getElementById('inputActivo').checked = true;
            document.getElementById('inputCategory').value = '';
        }

    </script>
}

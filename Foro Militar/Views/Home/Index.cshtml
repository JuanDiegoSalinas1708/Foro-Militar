@{
    ViewBag.Title = "Inicio";
}

<!-- HERO -->
<section class="hero">
    <h1>Eleva la discusión en <span>Corvax</span></h1>
    <p>Nido sin Filtro. Análisis estratégico, comunidades reales y debate sin ruido.</p>
    <div style="margin-top:40px;">
        <a class="btn-primary" href="@Url.Action("Register","Auth")">Comenzar ahora</a>
    </div>
</section>

<!-- QUÉ ES -->
<section class="section reveal">
    <div class="card">
        <h2>Una plataforma para mentes críticas</h2>
        <p style="margin-top:20px;">
            Corvax conecta comunidades enfocadas en análisis geopolítico,
            tecnología, estrategia y pensamiento estructurado.
        </p>
    </div>
</section>

<!-- CÓMO FUNCIONA -->
<section class="section reveal">
    <h2 style="text-align:center; margin-bottom:60px;">Cómo funciona</h2>
    <div class="grid-3">
        <div class="card">
            <h3>1. Únete</h3>
            <p>Explora comunidades especializadas.</p>
        </div>
        <div class="card">
            <h3>2. Analiza</h3>
            <p>Publica contenido con profundidad y contexto.</p>
        </div>
        <div class="card">
            <h3>3. Debate</h3>
            <p>Interactúa sin filtros superficiales.</p>
        </div>
    </div>
</section>

<!-- DIFERENCIAL -->
<section class="section reveal">
    <div class="grid-3">
        <div class="card">
            <h3>Sin ruido</h3>
            <p>Menos viralidad, más calidad.</p>
        </div>
        <div class="card">
            <h3>Comunidades reales</h3>
            <p>Enfoque estructurado por temática.</p>
        </div>
        <div class="card">
            <h3>Arquitectura moderna</h3>
            <p>Construido con enfoque técnico y escalable.</p>
        </div>
    </div>
</section>

<!-- SHOWCASE VISUAL -->
<section class="section reveal">
    <div class="card" style="text-align:center;">
        <h2>Diseñado para profundidad</h2>
        <p style="margin:20px 0;">
            Una experiencia limpia, enfocada y moderna.
        </p>
        <div style="height:200px; border-radius:12px; background:var(--bg-elevated); display:flex; align-items:center; justify-content:center;">
            <span style="color:var(--primary); font-weight:600;">
                Vista previa de comunidades
            </span>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="section reveal">
    <div class="card" style="text-align:center;">
        <h2>Únete al Nido</h2>
        <p style="margin:20px 0;">
            Forma parte de una nueva generación de discusión estratégica.
        </p>
        <a class="btn-primary" href="@Url.Action("Register","Auth")">
            Crear cuenta
        </a>
    </div>
</section>